# Weather API (if you want to use real weather data in WorldClock widget)
REACT_APP_WEATHER_API_KEY=your_openweathermap_api_key_here

# Global game leaderboards (Breakout top-N + DoodleJump/Juggling/Dino high score):
# backs the /api/leaderboard serverless function.
# Create a free Upstash Redis DB (or add the Upstash integration in the Vercel
# dashboard, which injects these automatically). Without them the leaderboard
# simply stays hidden; the game still works. KV_REST_API_* names are also accepted.
UPSTASH_REDIS_REST_URL=your_upstash_rest_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token_here

# Optional: lets you read players' (private) emails. With this set, GET
# /api/leaderboard?game=breakout&admin=<this value> includes the email field.
# Public requests never see emails. Use a long random string.
LEADERBOARD_ADMIN_TOKEN=